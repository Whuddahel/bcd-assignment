# ═══════════════════════════════════════════════════════════
#  Aureon — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  When DEVELOPMENT_MODE=true (default), all external services
#  fall back to mock implementations — no real keys needed.
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to false when you have real credentials for all services below.
# When true: mock auth, mock Stripe, console-logged emails.
DEVELOPMENT_MODE=true


# ── Supabase ─────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the client, server-only
# Found at Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ── Stripe ───────────────────────────────────────────────
# 1. Create an account at https://stripe.com
# 2. Go to Developers → API Keys
# 3. Use test keys for development (prefix: pk_test_ / sk_test_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — from Stripe Dashboard → Developers → Webhooks
# For local testing: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform fee percentage Aureon charges on each transaction (default: 10%)
STRIPE_PLATFORM_FEE_PERCENT=10


# ── Resend (Transactional Email) ──────────────────────────
# 1. Create an account at https://resend.com
# 2. Go to API Keys → Create API Key
# 3. Add and verify your sending domain in Resend → Domains
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@aureon.io


# ── Google OAuth ─────────────────────────────────────────
# Configured via Supabase Auth → Providers → Google
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add redirect URI: https://your-project.supabase.co/auth/v1/callback
# 4. Paste Client ID and Secret into Supabase Auth settings
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret


# ── Apple OAuth ──────────────────────────────────────────
# Configured via Supabase Auth → Providers → Apple
# 1. Go to https://developer.apple.com → Certificates, Identifiers & Profiles
# 2. Create a Services ID and enable "Sign in with Apple"
# 3. Create a Key with "Sign in with Apple" capability
# 4. Download the .p8 private key file
APPLE_CLIENT_ID=com.yourcompany.aureon
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
